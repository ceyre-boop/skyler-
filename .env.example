# Neon PostgreSQL — neon.tech → project → connection string (pooled)
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Session encryption — generate with: openssl rand -hex 32
SESSION_SECRET=

# Cloudinary (video storage) — cloudinary.com → Dashboard → Product Environment Credentials.
# Uploads go browser→Cloudinary via a signed request; the secret never reaches the client.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# TikTok Content Posting API — leave empty to disable TikTok auto-posting.
# Create at https://developers.tiktok.com → app with Login Kit + Content Posting API
# Scopes: user.info.basic, video.publish
# Redirect URI: https://YOUR_DOMAIN/api/tiktok/callback
# Note: posts are SELF_ONLY (private drafts) until TikTok approves your developer app.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Meta (Instagram + Facebook) — leave empty to disable Meta auto-posting.
# Create at https://developers.facebook.com → app → add Instagram + Facebook Login products
# Add users as test users in Developer Mode (no review needed for up to 25 users)
# Redirect URI: https://YOUR_DOMAIN/api/meta/callback
# Note: Instagram must be a creator or business account. Facebook requires a Page (not personal profile).
META_APP_ID=
META_APP_SECRET=
